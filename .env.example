# Copy this file to .env and fill in any values for local development.
# On Heroku, set these via the Heroku dashboard or CLI.
# On Vercel, set these in the Vercel project settings.

# Port for local development (Heroku sets this automatically)
PORT=3000

# Optional: set to "1" when running on Vercel (Vercel sets this automatically)
# VERCEL=1
