# Copy this file to .env and fill in any values for local development.
# On Heroku / Vercel, set these via the dashboard or CLI.

# ── Shared ────────────────────────────────────────────────────────────────

# Port for local development (Heroku/Vercel set this automatically)
PORT=3000

# Optional: set to "1" when running on Vercel
# VERCEL=1

# ── packages/mcp ──────────────────────────────────────────────────────────

# OpenRouter API key — required for /api/chat and design-system generation
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# OpenRouter model to use (defaults to openai/gpt-oss-20b:nitro if not set)
OPENROUTER_MODEL=openai/gpt-oss-20b:nitro

# Neon PostgreSQL connection string — required for persistent data store and metrics
# Create a project at https://neon.tech and copy the connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase JWT secret — required to validate auth tokens from packages/app
# Found in Supabase dashboard → Project Settings → API → JWT secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── packages/app ──────────────────────────────────────────────────────────

# Supabase project URL and anon key
# Found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# MCP server URL (point to your deployed packages/mcp instance)
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3000
MCP_SERVER_URL=http://localhost:3000
