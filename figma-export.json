  "layouts": {
    "_comment": "Figma layout frames representing common page-level compositions and grid configurations.",

    "PageShell": {
      "figmaNodeId": "200:10",
      "description": "Standard application page shell with fixed header, optional sidebar, and scrollable content area.",
      "structure": {
        "type": "FRAME",
        "layoutMode": "VERTICAL",
        "width": 1440,
        "fills": [{ "variable": "color/background/default" }],
        "children": [
          {
            "name": "Header",
            "type": "FRAME",
            "layoutMode": "HORIZONTAL",
            "width": "FILL",
            "height": 64,
            "fills": [{ "variable": "color/background/default" }],
            "strokeBottom": [{ "variable": "color/border/default" }],
            "paddingHorizontal": { "variable": "spacing/24" },
            "itemSpacing": { "variable": "spacing/16" }
          },
          {
            "name": "Body",
            "type": "FRAME",
            "layoutMode": "HORIZONTAL",
            "width": "FILL",
            "layoutGrow": 1,
            "children": [
              {
                "name": "Sidebar",
                "type": "FRAME",
                "layoutMode": "VERTICAL",
                "width": 240,
                "fills": [{ "variable": "color/background/subtle" }],
                "strokeRight": [{ "variable": "color/border/default" }],
                "paddingTop": { "variable": "spacing/24" },
                "paddingHorizontal": { "variable": "spacing/16" }
              },
              {
                "name": "Content",
                "type": "FRAME",
                "layoutMode": "VERTICAL",
                "layoutGrow": 1,
                "padding": { "variable": "spacing/32" },
                "itemSpacing": { "variable": "spacing/24" }
              }
            ]
          }
        ]
      }
    },

    "ContentGrid": {
      "figmaNodeId": "200:55",
      "description": "12-column responsive content grid used within page content areas.",
      "gridConfig": {
        "columns": 12,
        "columnWidth": "auto",
        "gutterWidth": { "variable": "spacing/24" },
        "margin": { "variable": "spacing/32" },
        "breakpoints": {
          "sm":  { "minWidth": 0,    "columns": 4, "gutter": 16, "margin": 16 },
          "md":  { "minWidth": 768,  "columns": 8, "gutter": 24, "margin": 24 },
          "lg":  { "minWidth": 1024, "columns": 12, "gutter": 24, "margin": 32 },
          "xl":  { "minWidth": 1280, "columns": 12, "gutter": 32, "margin": 48 }
        }
      }
    },

    "FormLayout": {
      "figmaNodeId": "200:92",
      "description": "Vertical stacked form layout with consistent label/field/helper spacing.",
      "structure": {
        "type": "FRAME",
        "layoutMode": "VERTICAL",
        "itemSpacing": { "variable": "spacing/24" },
        "children": [
          {
            "name": "FormField",
            "type": "FRAME",
            "layoutMode": "VERTICAL",
            "itemSpacing": { "variable": "spacing/8" },
            "children": [
              { "name": "Label",       "component": "Label" },
              { "name": "InputField",  "component": "Input" },
              { "name": "HelperText",  "component": "HelperText", "optional": true }
            ]
          },
          {
            "name": "FormActions",
            "type": "FRAME",
            "layoutMode": "HORIZONTAL",
            "itemSpacing": { "variable": "spacing/12" },
            "children": [
              { "name": "PrimaryAction",   "component": "Button", "variant": "Primary" },
              { "name": "SecondaryAction", "component": "Button", "variant": "Secondary", "optional": true }
            ]
          }
        ]
      }
    },

    "CardGrid": {
      "figmaNodeId": "200:130",
      "description": "Auto-layout grid for displaying collections of Card components.",
      "structure": {
        "type": "FRAME",
        "layoutMode": "HORIZONTAL",
        "layoutWrap": "WRAP",
        "itemSpacing": { "variable": "spacing/24" },
        "counterAxisSpacing": { "variable": "spacing/24" },
        "children": [
          {
            "name": "Card",
            "component": "Card",
            "variant": "Elevated",
            "width": 320,
            "layoutGrow": 1
          }
        ]
      }
