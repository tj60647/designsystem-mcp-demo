{
  "name": "designsystem-mcp-demo",
  "version": "0.3.0",
  "description": "Design System MCP — a queryable context layer that makes design systems machine-readable and usable by AI",
  "author": "Thomas J McLeish",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/copy-data.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "heroku-postbuild": "npm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:api": "node --import tsx/esm --test tests/api.test.ts",
    "test:evals": "promptfoo eval --config evals/promptfooconfig.yaml",
    "ws:dev": "turbo dev",
    "ws:build": "turbo build",
    "ws:typecheck": "turbo typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "playwright": "^1.58.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "promptfoo": "^0.121.3",
    "tsx": "^4.7.0",
    "turbo": "^2.5.4",
    "typescript": "^5.3.3"
  }
}
