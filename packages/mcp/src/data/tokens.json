  "motion": {
    "duration": {
      "instant": {
        "$value": "0ms",
        "$type": "duration",
        "$description": "No animation \u2014 immediate state change"
      },
      "fast": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Micro-interactions such as button press feedback"
      },
      "normal": {
        "$value": "200ms",
        "$type": "duration",
        "$description": "Default transition for most UI state changes"
      },
      "slow": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Larger or more complex transitions"
      },
      "slower": {
        "$value": "500ms",
        "$type": "duration",
        "$description": "Entrance/exit of large surfaces such as modals"
      }
    },
    "easing": {
      "linear": {
        "$value": "linear",
        "$type": "cubicBezier",
        "$description": "Constant velocity \u2014 use for opacity fades"
      },
      "easeIn": {
        "$value": "cubic-bezier(0.4, 0, 1, 1)",
        "$type": "cubicBezier",
        "$description": "Starts slow, ends fast \u2014 use for element exits"
      },
      "easeOut": {
        "$value": "cubic-bezier(0, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Starts fast, ends slow \u2014 use for element entrances"
      },
      "easeInOut": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Default ease for continuous transitions"
      },
      "spring": {
        "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "$type": "cubicBezier",
        "$description": "Slight overshoot for playful, physical feel"
      }
    },
    "transition": {
      "quick": {
        "$value": "all {motion.duration.fast} {motion.easing.easeOut}",
        "$type": "transition",
        "$description": "Shorthand for fast micro-interaction transitions"
      },
      "base": {
        "$value": "all {motion.duration.normal} {motion.easing.easeInOut}",
        "$type": "transition",
        "$description": "Default shorthand for common state transitions"
      },
      "slow": {
        "$value": "all {motion.duration.slow} {motion.easing.easeInOut}",
        "$type": "transition",
        "$description": "Shorthand for slower surface transitions"
      }
    }
  },
