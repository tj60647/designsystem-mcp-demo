    "modal": {
      "name": "Modal",
      "description": "Overlay dialog for focused tasks or confirmations that interrupt the user workflow.",
      "variants": ["default", "alert"],
      "sizes": ["sm", "md", "lg", "fullscreen"],
      "states": ["closed", "open", "loading"],
      "props": {
        "isOpen":      { "type": "boolean", "required": true },
