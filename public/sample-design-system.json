    "toast": {
      "name": "Toast",
      "description": "Ephemeral notification that appears in a corner of the screen. Used for non-blocking status feedback.",
      "variants": ["info", "success", "warning", "error"],
      "states": ["entering", "visible", "exiting"],
      "props": {
        "message":   { "type": "string", "required": true },
        "variant":   { "type": "enum", "values": ["info", "success", "warning", "error"], "default": "info" },
        "duration":  { "type": "number", "default": 5000, "description": "Auto-dismiss duration in ms. 0 = persist." },
        "action":    { "type": "object", "optional": true, "description": "Optional { label: string, onClick: fn } action button" },
        "onDismiss": { "type": "function", "optional": true }
      },
