        "title":       { "type": "string", "required": true },
        "size":        { "type": "enum", "values": ["sm", "md", "lg", "fullscreen"], "default": "md" },
        "variant":     { "type": "enum", "values": ["default", "alert"], "default": "default" },
        "isDismissible": { "type": "boolean", "default": true, "description": "Whether clicking the backdrop closes the modal" },
        "children":    { "type": "ReactNode", "required": true }
      },
      "tokens": {
        "background":    "{color.neutral.0}",
