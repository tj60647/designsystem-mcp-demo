      "relationships": {
        "parent": ["App root"],
        "relatedComponents": ["Dialog", "Drawer", "Popover", "AlertDialog"]
      },
      "variantGuidance": {
        "default": "Standard task-completion dialogs, forms, confirmations.",
        "alert": "Critical confirmations (e.g., delete, destructive actions). Not dismissible by backdrop."
      }
