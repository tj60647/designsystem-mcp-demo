        "shadow":       "{shadow.xl}",
        "zIndex":       "{layout.zIndex.toast}",
        "animation":    "{motion.duration.slow} {motion.easing.easeOut}"
      },
      "constraints": [
        "Toasts must auto-dismiss (default 5 seconds) unless they contain an action.",
        "Display no more than 3 toasts simultaneously.",
        "Do not use toasts for errors that require user action — use an inline error instead.",
        "Toast messages must be concise (max 80 characters).",
        "Toasts must pause auto-dismiss on hover."
      ],
      "accessibility": {
        "role": "status (info/success) or alert (warning/error)",
        "ariaAttributes": ["aria-live='polite' for info/success", "aria-live='assertive' for warning/error"],
        "keyboardSupport": ["Dismiss button must be keyboard-accessible"]
      },
      "anatomy": {
        "root": "div[role='status'] or div[role='alert']",
        "slots": {
          "icon": "Leading status icon",
          "message": "Notification text",
          "action": "Optional text button",
          "dismiss": "Close button"
        },
        "validChildren": ["Icon", "text", "Button"],
        "compositionNotes": "Rendered in a ToastProvider portal at the app root. Do not position manually."
      },
      "relationships": {
        "parent": ["ToastProvider"],
        "relatedComponents": ["Alert", "Banner", "Snackbar"]
      },
      "variantGuidance": {
        "info":    "Neutral updates — item saved, process started.",
        "success": "Completed actions — file uploaded, changes saved.",
        "warning": "Soft warnings that don't block the user.",
        "error":   "Recoverable errors where context is lost — use inline errors for form failures."
      }
