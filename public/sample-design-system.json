          "md":         "560px",
          "lg":         "840px",
          "fullscreen": "100vw"
        },
        "zIndex": "{layout.zIndex.modal}"
      },
      "constraints": [
        "Modals must trap focus while open.",
        "Modals must close on Escape key.",
        "Avoid stacking more than one modal at a time.",
        "Alert modals must not be dismissible via backdrop click.",
        "The modal trigger must regain focus when the modal closes."
      ],
      "accessibility": {
        "role": "dialog",
        "ariaAttributes": ["aria-modal='true'", "aria-labelledby pointing to modal title", "aria-describedby for modal body if needed"],
        "keyboardSupport": ["Escape — close", "Tab — cycle focus within modal", "Shift+Tab — reverse focus cycle"],
        "focusManagement": "First focusable element receives focus on open. Trigger element receives focus on close."
      },
      "anatomy": {
        "root": "div[role='dialog']",
        "slots": {
          "overlay": "Full-screen backdrop",
          "container": "Centred modal container",
          "header": "Title + close button row",
          "body": "Scrollable content area",
          "footer": "Action buttons row"
        },
        "validChildren": ["ModalHeader", "ModalBody", "ModalFooter"],
        "compositionNotes": "Always include a visible title in ModalHeader. ModalFooter should contain primary and secondary actions."
