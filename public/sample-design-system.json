      "constraints": [
        "Button label must be concise — 1–4 words. Use tooltips for additional context.",
        "Destructive buttons must be separated from non-destructive actions by at least 8px.",
        "Loading state must disable interaction and show a spinner.",
        "Icon-only buttons must include an aria-label.",
        "Do not use ghost variant as the sole primary action on a page.",
        "Maximum one primary button per visible viewport region."
      ],
      "accessibility": {
        "role": "button",
        "keyboardSupport": ["Enter — activate", "Space — activate"],
        "ariaAttributes": ["aria-disabled when disabled", "aria-busy when loading", "aria-label for icon-only buttons"],
        "focusManagement": "Must be included in the natural tab order. Focus ring must meet 3:1 contrast ratio."
      },
      "anatomy": {
        "root": "button[type='button']",
        "slots": {
          "leftIcon": "Optional leading icon (16px for sm/md, 20px for lg)",
          "label": "Required text content",
          "rightIcon": "Optional trailing icon",
          "spinner": "Visible only when loading=true"
        },
        "validChildren": ["Icon", "text"],
        "compositionNotes": "Icon size should match text size. Use the Icon component for leftIcon and rightIcon slots."
      },
